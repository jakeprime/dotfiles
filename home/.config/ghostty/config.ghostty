config-file = ?"~/.config/omarchy/current/theme/ghostty.conf"

window-padding-x = 16

font-family = "SpaceMono Nerd Font Mono"
font-size = 12

text-glow-radius = 14
text-glow-intensity = 1.0
palette-glow = 9
palette-glow = 10
palette-glow = 11
palette-glow = 12
palette-glow = 13
palette-glow = 14

bold-text-glow = true
font-style-bold = false

font-feature = -calt

config-file = ~/.config/ghostty/local.ghostty
